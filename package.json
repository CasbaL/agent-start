{
  "name": "agent-start",
  "version": "1.0.0",
  "description": "Node AI agent demo for intent-based repository matching and LLM summarization",
  "main": "index.js",
  "scripts": {
    "start": "tsx index.ts",
    "self-check": "tsx index.ts --self-check",
    "dev": "tsx watch index.ts",
    "demo:offline": "tsx index.ts --offline --debug \"帮我推荐适合做 Node.js AI Agent 的仓库\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@openrouter/ai-sdk-provider": "^2.3.3",
    "ai": "^6.0.145",
    "dotenv": "^17.4.0",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
